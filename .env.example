# Copy to .env and fill in. .env is gitignored.

# Postgres connection — default matches docker-compose.yml
DATABASE_URL=postgres://lobby:lobby@localhost:5432/lobbying

# Free API key — https://lda.senate.gov/api/register/
# Optional but STRONGLY recommended. Without it the ingester hits rate
# limits frequently and takes much longer.
LDA_API_KEY=

# Free FEC key — https://api.data.gov/signup/
# Only needed if you run ingest_fec.py
FEC_API_KEY=
